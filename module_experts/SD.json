{
  "module": "SD",
  "module_name": "Sales & Distribution",
  "sap_connection": {
    "username_env": "SAP_USER",
    "password_env": "SAP_PASSWORD",
    "timeout_ms": 10000,
    "csrf_ttl_minutes": 5
  },
  "defaults": {
    "sales_org": "1000",
    "dist_channel": "10",
    "division": "00"
  },
  "query_limits": {
    "max_records_per_query": 5,
    "max_queries_per_session": 20
  },
  "cache": {
    "enabled": true,
    "scope": "by_process_family",
    "ttl_minutes": 60
  },
  "anonymization": {
    "enabled": true,
    "rules": [
      {
        "field": "KUNNR",
        "category": "customer_id",
        "strategy": "token",
        "token_prefix": "CUST_",
        "send_to_llm": "token",
        "show_to_tester": "real_if_local"
      },
      {
        "field": "NAME1",
        "category": "company_name",
        "strategy": "suppress",
        "send_to_llm": "never",
        "show_to_tester": "never"
      },
      {
        "field": "MATNR",
        "category": "material_id",
        "strategy": "token",
        "token_prefix": "MAT_",
        "send_to_llm": "token",
        "show_to_tester": "real_if_local"
      },
      {
        "field": "ARKTX",
        "category": "material_description",
        "strategy": "generalize",
        "send_to_llm": "generalized",
        "show_to_tester": "generalized"
      },
      {
        "field": "MAKTX",
        "category": "material_description",
        "strategy": "generalize",
        "send_to_llm": "generalized",
        "show_to_tester": "generalized"
      },
      {
        "field": "NETPR",
        "category": "price",
        "strategy": "range",
        "send_to_llm": "range",
        "show_to_tester": "real_if_local"
      },
      {
        "field": "KWMENG",
        "category": "quantity",
        "strategy": "range",
        "send_to_llm": "range",
        "show_to_tester": "real_if_local"
      },
      {
        "field": "VBELN",
        "category": "document_number",
        "strategy": "token",
        "token_prefix": "DOC_",
        "send_to_llm": "token",
        "show_to_tester": "real_if_local"
      },
      {
        "field": "LIFNR",
        "category": "vendor_id",
        "strategy": "token",
        "token_prefix": "VEND_",
        "send_to_llm": "token",
        "show_to_tester": "real_if_local"
      },
      {
        "field": "ZTERM",
        "category": "payment_terms",
        "strategy": "keep",
        "send_to_llm": "real",
        "show_to_tester": "real"
      },
      {
        "field": "AUART",
        "category": "order_type",
        "strategy": "keep",
        "send_to_llm": "real",
        "show_to_tester": "real"
      },
      {
        "field": "VKORG",
        "category": "sales_org",
        "strategy": "keep",
        "send_to_llm": "real",
        "show_to_tester": "real"
      },
      {
        "field": "VTWEG",
        "category": "distribution_channel",
        "strategy": "keep",
        "send_to_llm": "real",
        "show_to_tester": "real"
      },
      {
        "field": "SPART",
        "category": "division",
        "strategy": "keep",
        "send_to_llm": "real",
        "show_to_tester": "real"
      },
      {
        "field": "WERKS",
        "category": "plant",
        "strategy": "keep",
        "send_to_llm": "real",
        "show_to_tester": "real"
      },
      {
        "field": "LGORT",
        "category": "storage_location",
        "strategy": "keep",
        "send_to_llm": "real",
        "show_to_tester": "real"
      },
      {
        "field": "INCO1",
        "category": "incoterm",
        "strategy": "keep",
        "send_to_llm": "real",
        "show_to_tester": "real"
      }
    ],
    "range_bands": {
      "price": [
        { "max": 100, "label": "< 100" },
        { "max": 1000, "label": "100 - 1.000" },
        { "max": 10000, "label": "1.000 - 10.000" },
        { "min": 10000, "label": "> 10.000" }
      ],
      "quantity": [
        { "max": 10, "label": "< 10 unidades" },
        { "max": 100, "label": "10 - 100 unidades" },
        { "max": 1000, "label": "100 - 1.000 unidades" },
        { "min": 1000, "label": "> 1.000 unidades" }
      ]
    }
  }
}
