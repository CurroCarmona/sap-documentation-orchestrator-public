      "table": "VBRK",
      "priority": "mandatory",
      "fields": [
        "VBELN",
        "FKART",
        "FKDAT",
        "VKORG",
        "VTWEG",
        "SPART",
        "KUNRG",
        "KUNAG",
        "ERDAT",
