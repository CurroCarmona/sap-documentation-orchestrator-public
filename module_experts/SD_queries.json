      ],
      "filter_strategy": {
        "anchor_fields": ["FKART", "VKORG", "KUNRG"],
        "date_field": "ERDAT",
        "date_range_days": 90
      },
      "sql_template": "SELECT {fields} FROM VBRK WHERE {filters} ORDER BY ERDAT DESC"
    },
    "billing_item": {
      "id": "billing_item",
      "description": "Ítems de factura",
      "table": "VBRP",
      "priority": "mandatory",
      "depends_on": "billing_header",
      "join_key": "VBELN",
      "fields": [
        "VBELN",
        "POSNR",
        "MATNR",
        "ARKTX",
        "FKIMG",
        "VRKME",
        "NETWR",
        "WERKS",
        "AUBEL",
        "AUPOS"
      ],
      "filter_strategy": {
        "anchor_fields": ["VBELN"],
        "mandatory_filters": ["VBELN"]
      },
      "sql_template": "SELECT {fields} FROM VBRP WHERE {filters}"
    },
    "quotation_header": {
      "id": "quotation_header",
