        "KNUMV",
        "KPOSN",
        "KSCHL",
        "KBETR",
        "WAERS"
      ],
      "filter_strategy": {
        "anchor_fields": ["KNUMV"]
      },
      "sql_template": "SELECT {fields} FROM KONV WHERE {filters}"
    },
    "delivery_header": {
      "id": "delivery_header",
      "description": "Cabecera de entrega",
      "table": "LIKP",
      "priority": "mandatory",
      "fields": [
        "VBELN",
        "LFART",
        "VSTEL",
        "VKORG",
        "KUNNR",
        "ERDAT",
        "WADAT",
        "LFDAT"
      ],
      "filter_strategy": {
        "anchor_fields": ["LFART", "VSTEL", "KUNNR"],
        "date_field": "ERDAT",
        "date_range_days": 90
      },
      "sql_template": "SELECT {fields} FROM LIKP WHERE {filters} ORDER BY ERDAT DESC"
