{
  "ts-node": {
    "transpileOnly": false,
    "compilerOptions": {
      "module": "commonjs",
      "verbatimModuleSyntax": false,
      "moduleDetection": "force"
    }
  },
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "moduleResolution": "node",
    "moduleDetection": "force",
    "strict": false,
    "verbatimModuleSyntax": false,
    "noUncheckedIndexedAccess": false,
    "strictNullChecks": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}